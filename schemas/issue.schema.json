{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ChatGPT Haber Issue",
  "type": "object",
  "required": ["issue", "pages"],
  "properties": {
    "issue": {
      "type": "object",
      "required": ["issue_date", "edition_name", "language", "page_count", "paper_size", "title"],
      "properties": {
        "issue_date": { "type": "string" },
        "edition_name": { "type": "string" },
        "language": { "type": "string", "const": "tr-TR" },
        "page_count": { "type": "integer", "enum": [3, 4] },
        "paper_size": { "type": "string", "enum": ["A3", "A4"] },
        "title": { "type": "string" },
        "timezone": { "type": "string" },
        "generated_at": { "type": "string" },
        "edition_note": { "type": "string" }
      }
    },
    "pages": {
      "type": "array",
      "minItems": 3,
      "maxItems": 4,
      "items": {
        "type": "object",
        "required": ["page_no", "template", "name", "articles"],
        "properties": {
          "page_no": { "type": "integer", "minimum": 1, "maximum": 4 },
          "template": { "type": "string", "enum": ["front_page", "news_page", "radar_page"] },
          "name": { "type": "string" },
          "articles": { "type": "array", "items": { "$ref": "#/$defs/article" } },
          "briefs": { "type": "array", "items": { "$ref": "#/$defs/article" } }
        }
      }
    }
  },
  "$defs": {
    "article": {
      "type": "object",
      "required": ["id", "section", "headline", "dek", "body", "source_bundle", "verification", "layout_hint"],
      "properties": {
        "id": { "type": "string" },
        "section": { "type": "string" },
        "kicker": { "type": "string" },
        "headline": { "type": "string" },
        "dek": { "type": "string" },
        "body": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "image": { "type": "object" },
        "source_bundle": { "type": "array", "minItems": 1 },
        "verification": { "type": "object" },
        "layout_hint": { "type": "object" }
      }
    }
  }
}
